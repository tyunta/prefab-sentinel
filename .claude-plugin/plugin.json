{
  "name": "prefab-sentinel",
  "version": "0.5.48",
  "description": "Unity Prefab/Scene/Asset の検査・編集・参照修復ツール",
  "author": {
    "name": "tyunta",
    "url": "https://github.com/tyunta"
  },
  "repository": "https://github.com/tyunta/prefab-sentinel",
  "license": "MIT",
  "keywords": ["unity", "prefab", "validation", "inspection", "reference", "patch"],
  "mcpServers": {
    "prefab-sentinel": {
      "command": "uvx",
      "args": [
        "--from", "${CLAUDE_PLUGIN_ROOT}",
        "--with", "mcp>=1.12",
        "prefab-sentinel-mcp"
      ]
    }
  }
}
